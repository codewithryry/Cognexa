# Copy this file to .env and adjust for your environment.
# Local dev (HeidiSQL pointing at a local MySQL server):
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/cognexa

# When deploying online, point this at your hosted MySQL instance instead, e.g.:
# DATABASE_URL=mysql+pymysql://<user>:<password>@<host>:3306/<database>

# Secret used to sign JWT auth tokens. Falls back to an insecure dev value if
# unset -- ALWAYS set this to a unique random value before deploying.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=48a35fc16476465376bbed428d2eaa0cb764d1372f2c4ec4d8c618df6b0ad454
